#[cfg(feature = "datagen")]
impl databake::Bake for {{ prop.name.to_upper_camel_case() }} {
    fn bake(&self, env: &databake::CrateEnv) -> databake::TokenStream {
        env.insert("icu_properties");
        match *self {
            {%- for (discriminant, (_, long_name, _)) in prop.variants() %}
            {%- if (discriminant != 254 || long_name != "Chisoi") %}
            Self::{{prop.transform_ident(long_name)}} => databake::quote!(icu_properties::props::{{ prop.name.to_upper_camel_case() }}::{{prop.transform_ident(long_name)}}),
            {%- endif %}
            {%- endfor %}
            {%- if prop.is_open() %}
            Self(v) => databake::quote!(icu_properties::props::{{ prop.name.to_upper_camel_case() }}(#v)),
            {%- endif %}
        }
    }
}


impl From<{{ prop.name.to_upper_camel_case() }}> for u16  {
    fn from(other: {{ prop.name.to_upper_camel_case() }}) -> Self {
        {%- if !prop.is_open() %}
        other as u16
        {%- else if prop.int_type() == "u8" %}
        other.0 as u16
        {%- else %}
        other.0
        {%- endif %}
    }
}

