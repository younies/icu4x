{%- for prop in props %}

{%- if prop.is_open() %}

impl {{ prop.name.to_upper_camel_case() }} {
    {%- for (discriminant, (short_name, long_name, aliases)) in prop.variants() %}
    {%- if (discriminant != 254 || long_name != "Chisoi") %}
    {%- if prop.is_icu4c_only_value(*discriminant) && prop.name == "Script" %}
    /// ISO 15924
    {%- endif %}
    pub const {{prop.transform_ident(long_name)}}: Self = Self({{discriminant}});
    {%- if short_name != long_name %}
    {%- if prop.is_icu4c_only_value(*discriminant) && prop.name == "Script" %}
    /// ISO 15924
    {%- endif %}
    pub const {{prop.transform_ident(short_name)}}: Self = Self::{{prop.transform_ident(long_name)}};
    {%- endif %}
    {%- for alias in aliases %}
    {%- if prop.is_icu4c_only_value(*discriminant) && prop.name == "Script" %}
    /// ISO 15924
    {%- endif %}
    pub const {{prop.transform_ident(alias)}}: Self = Self::{{prop.transform_ident(long_name)}};
    {%- endfor %}
    {%- endif %}
    {%- endfor %}
}

